# Environment variables for Hub Central
NODE_ENV=development
PORT=3002

# Database configuration
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=root
DB_PASSWORD=password
DB_NAME=hub_central

# Redis configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Ecosystem APIs configuration
GRAF_API_URL=http://localhost:3000
GRAF_API_KEY=your_graf_api_key

EMW_API_URL=http://localhost:3001
EMW_API_KEY=your_emw_api_key

MERAVUELTA_API_URL=http://localhost:3006
MERAVUELTA_API_KEY=your_meravuelta_api_key

FIAR_API_URL=http://localhost:3002
FIAR_API_KEY=your_fiar_api_key

SINERGIA_API_URL=http://localhost:3003
SINERGIA_API_KEY=your_sinergia_api_key

APISIGO_API_URL=http://localhost:3004
APISIGO_API_KEY=your_apisigo_api_key

# Si deseas que HubCentral firme las peticiones a ApiSigo, configura este secreto.
# Debe coincidir con HUB_WEBHOOK_SECRET en el servicio ApiSigo.
# Si no se define, HubCentral omitirá el header x-hub-signature (comportamiento recomendado por defecto).
APISIGO_HUB_WEBHOOK_SECRET=


# Security
JWT_SECRET=your_jwt_secret_for_hub_central
API_SECRET=your_hub_central_api_secret

# Hub Central API Key (debe coincidir con graf-backend)
HUB_CENTRAL_SECRET=graf-backend-secret-key-2024

# Webhook security
WEBHOOK_SECRET=your_webhook_secret

# Logging
LOG_LEVEL=debug
